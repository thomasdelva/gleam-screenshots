# Copy to .envrc (gitignored) and adjust for your machine.
# direnv users: run `direnv allow` after copying.
# Otherwise: `source .envrc` before running `gleam test`.

# A Chrome / Chromium executable.
#   macOS:  /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
#   Linux:  /usr/bin/google-chrome  (or a Chrome-for-Testing binary)
export CHROME_BIN="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# The odiff executable. `npm i` installs one here:
export ODIFF_BIN="node_modules/.bin/odiff"
